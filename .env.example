# ── Server ────────────────────────────────────────────────────────────
PORT=3000

# ── Domain ───────────────────────────────────────────────────────────
# Used by nginx reverse proxy and certbot
DOMAIN=schedule.yourdomain.com

# ── HRM Integration (optional) ───────────────────────────────────────
# Leave empty to use seed/sample data instead of live sync
HRM_API_URL=https://subdomain.ontimes.my.id
HRM_API_TOKEN=your-monitoring-integration-key

# ── Telegram Auth ─────────────────────────────────────────────────────
# Comma-separated Telegram user IDs with admin privileges
ADMIN_TELEGRAM_IDS=123456789,987654321

# Telegram Bot token for HMAC verification of Mini App initData
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# ── Cloudflare (for certbot DNS-01 challenge) ────────────────────────
# API token with DNS:Edit permission on the zone.
# Generate at: https://dash.cloudflare.com/profile/api-tokens
# Then copy it into: nginx/cloudflare.ini
