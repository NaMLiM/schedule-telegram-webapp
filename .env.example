# ── Server ────────────────────────────────────────────────────────────
PORT=3000

# ── HRM Integration (optional) ───────────────────────────────────────
# Leave empty to use seed/sample data instead of live sync
HRM_API_URL=https://subdomain.ontimes.my.id
HRM_API_TOKEN=your-m…-key

# ── Telegram Auth ─────────────────────────────────────────────────────
# Comma-separated Telegram user IDs with admin privileges
ADMIN_TELEGRAM_IDS=123456789,987654321

# Telegram Bot token for HMAC verification of Mini App initData
BOT_TOKEN=123456…ew11
